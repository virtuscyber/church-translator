# Church Live Translation — Environment Variables
# Copy to .env and fill in real values

OPENAI_API_KEY=sk-your-openai-key-here
ELEVENLABS_API_KEY=your-elevenlabs-key-here
# Optional — only needed if you select the Deepgram STT provider
DEEPGRAM_API_KEY=your-deepgram-key-here

# Dashboard settings (optional)
DASHBOARD_PORT=8085
DASHBOARD_HOST=127.0.0.1
# Set a secret token to require auth. STRONGLY recommended if DASHBOARD_HOST is
# not 127.0.0.1 (e.g. in Docker, where it binds to 0.0.0.0).
DASHBOARD_API_KEY=your-secret-dashboard-token
DASHBOARD_CORS_ORIGIN=http://localhost:8085
